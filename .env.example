# MapIt Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. This file (.env.example) is safe to commit.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# ⚠️  SERVICE ROLE KEY — never expose in frontend code
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DB_PASSWORD=your-supabase-db-password

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
# Values: development | production | test
NODE_ENV=development
# Production: https://mapit.co.in  |  Local: http://localhost:3001
APP_URL=http://localhost:3001

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-min-64-chars

# ─── Storage ─────────────────────────────────────────────────────────────────
# Supabase Storage bucket name (create in Supabase dashboard → Storage)
STORAGE_BUCKET=listing-photos
# Max file size in bytes (default: 10MB = 10485760)
MAX_PHOTO_SIZE=10485760
# Max photos per listing (enforced in multer + frontend)
MAX_PHOTOS_PER_LISTING=5

# ─── Auth Gating ─────────────────────────────────────────────────────────────
# Set to false for MVP (invite codes no longer used)
REQUIRE_INVITE_CODE=false

# ─── Email ───────────────────────────────────────────────────────────────────
# Sender name shown in email clients
EMAIL_FROM_NAME=MapIt

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# Max OTP requests per hour per IP
OTP_RATE_LIMIT=100

# ─── MVP Additions (Session 2+) ──────────────────────────────────────────────
# Google OAuth — from Supabase dashboard → Auth → Providers → Google
# (No value needed here; configured directly in Supabase dashboard)

# Twilio SMS OTP — from twilio.com/console
# Required for Session 2 (mobile OTP login)
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Resend — from resend.com/api-keys
# Used for transactional email (seller "I'm Interested" notification — Session 5)
RESEND_API_KEY=re_your-resend-api-key
